{
 "align_labels_right": 0,
 "creation": "2026-03-27 04:10:00.000000",
 "custom_format": 0,
 "default_print_language": "ar",
 "disabled": 0,
 "doc_type": "Employee Loan",
 "doctype": "Print Format",
 "font": "Default",
 "html": "<!DOCTYPE html>\n<html dir=\"rtl\" lang=\"ar\">\n<head>\n<meta charset=\"UTF-8\">\n<style>\n  body { font-family: 'Arial', 'Tahoma', 'DejaVu Sans', sans-serif; direction: rtl; color: #1f2937; margin: 0; padding: 28px 34px; font-size: 13px; }\n  .sheet { border: 1px solid #d1d5db; border-radius: 14px; overflow: hidden; }\n  .hero { background: linear-gradient(135deg, #0f766e, #14532d); color: #fff; padding: 24px 28px; }\n  .hero h1 { margin: 0 0 6px; font-size: 26px; }\n  .hero p { margin: 0; opacity: .92; }\n  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; padding: 20px 24px 0; }\n  .card { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 12px; padding: 14px 16px; }\n  .label { font-size: 11px; color: #6b7280; margin-bottom: 4px; }\n  .value { font-size: 15px; font-weight: bold; color: #111827; }\n  .section { padding: 18px 24px 0; }\n  .section h2 { margin: 0 0 10px; font-size: 17px; color: #14532d; }\n  .summary { background: #ecfeff; border: 1px solid #a5f3fc; border-radius: 12px; padding: 16px; line-height: 1.9; }\n  table { width: 100%; border-collapse: collapse; margin-top: 10px; }\n  th { background: #14532d; color: white; padding: 10px; font-size: 12px; }\n  td { padding: 9px 10px; border-bottom: 1px solid #e5e7eb; text-align: right; }\n  tr:nth-child(even) td { background: #f9fafb; }\n  .footer { padding: 26px 24px 28px; }\n  .signatures { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 24px; }\n  .signature-box { padding-top: 34px; border-top: 1px solid #9ca3af; text-align: center; color: #374151; }\n</style>\n</head>\n<body>\n{%- set installments = doc.installments or [] -%}\n<div class=\"sheet\">\n  <div class=\"hero\">\n    <h1>اتفاقية قرض موظف</h1>\n    <p>Employee Loan Agreement & Installment Schedule</p>\n  </div>\n  <div class=\"grid\">\n    <div class=\"card\"><div class=\"label\">الموظف</div><div class=\"value\">{{ doc.employee_name }} ({{ doc.employee }})</div></div>\n    <div class=\"card\"><div class=\"label\">الشركة / القسم</div><div class=\"value\">{{ doc.company }}{% if doc.department %} - {{ doc.department }}{% endif %}</div></div>\n    <div class=\"card\"><div class=\"label\">مبلغ القرض</div><div class=\"value\">{{ frappe.utils.fmt_money(doc.loan_amount, currency='SAR') }}</div></div>\n    <div class=\"card\"><div class=\"label\">تاريخ القرض</div><div class=\"value\">{{ frappe.format(doc.loan_date, 'Date') }}</div></div>\n    <div class=\"card\"><div class=\"label\">طريقة السداد</div><div class=\"value\">{{ doc.repayment_method }}</div></div>\n    <div class=\"card\"><div class=\"label\">بداية السداد</div><div class=\"value\">{{ frappe.format(doc.repayment_start_date, 'Date') }}</div></div>\n    <div class=\"card\"><div class=\"label\">حالة الاعتماد</div><div class=\"value\">{{ doc.approval_status or '-' }}</div></div>\n    <div class=\"card\"><div class=\"label\">حالة القرض</div><div class=\"value\">{{ doc.status or '-' }}</div></div>\n  </div>\n  <div class=\"section\">\n    <h2>بنود أساسية</h2>\n    <div class=\"summary\">\n      يقر الموظف باستلام مبلغ القرض الموضح أعلاه والالتزام بسداده وفق جدول الأقساط المعتمد.\n      يحق للشركة خصم الأقساط المستحقة من الراتب الشهري أو أي مستحقات مالية نظامية وفق الأنظمة واللوائح الداخلية المعتمدة.\n      {% if doc.notes %}<br><br><strong>ملاحظات:</strong> {{ doc.notes }}{% endif %}\n    </div>\n  </div>\n  <div class=\"section\">\n    <h2>جدول الأقساط</h2>\n    <table>\n      <thead>\n        <tr>\n          <th>رقم القسط</th>\n          <th>تاريخ الاستحقاق</th>\n          <th>مبلغ القسط</th>\n          <th>المسدّد</th>\n          <th>المتبقي</th>\n          <th>الحالة</th>\n        </tr>\n      </thead>\n      <tbody>\n        {% for row in installments %}\n        <tr>\n          <td>{{ row.installment_number }}</td>\n          <td>{{ frappe.format(row.due_date, 'Date') }}</td>\n          <td>{{ frappe.utils.fmt_money(row.installment_amount, currency='SAR') }}</td>\n          <td>{{ frappe.utils.fmt_money(row.deducted_amount, currency='SAR') }}</td>\n          <td>{{ frappe.utils.fmt_money(row.outstanding_amount, currency='SAR') }}</td>\n          <td>{{ row.deduction_status }}</td>\n        </tr>\n        {% endfor %}\n      </tbody>\n    </table>\n  </div>\n  <div class=\"footer\">\n    <div class=\"signatures\">\n      <div class=\"signature-box\">توقيع الموظف<br>Employee Signature</div>\n      <div class=\"signature-box\">اعتماد الموارد البشرية / المالية<br>HR / Finance Authorization</div>\n    </div>\n  </div>\n</div>\n</body>\n</html>\n",
 "idx": 0,
 "line_breaks": 0,
 "module": "Saudi HR",
 "name": "Employee Loan Agreement AR",
