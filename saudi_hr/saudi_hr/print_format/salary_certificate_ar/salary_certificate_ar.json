 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html dir=\"rtl\" lang=\"ar\">\n<head>\n<meta charset=\"UTF-8\">\n<style>\n  body {\n    font-family: 'Arial', 'Tahoma', 'DejaVu Sans', sans-serif;\n    direction: rtl;\n    font-size: 13px;\n    color: #1a1a1a;\n    margin: 0;\n    padding: 30px 40px;\n    background: #fff;\n  }\n  .header {\n    text-align: center;\n    border-bottom: 3px double #1a5276;\n    padding-bottom: 18px;\n    margin-bottom: 25px;\n  }\n  .company-logo {\n    max-height: 70px;\n    margin-bottom: 8px;\n  }\n  .header h1 {\n    font-size: 24px;\n    color: #1a5276;\n    margin: 6px 0 2px 0;\n    letter-spacing: 1px;\n  }\n  .header h2 {\n    font-size: 14px;\n    color: #555;\n    font-weight: normal;\n    margin: 0;\n  }\n  .cert-number {\n    font-size: 11px;\n    color: #888;\n    margin-top: 6px;\n  }\n  .issue-date {\n    text-align: left;\n    font-size: 12px;\n    color: #555;\n    margin-bottom: 20px;\n  }\n  .to-whom {\n    background: #eaf2f8;\n    border-right: 5px solid #1a5276;\n    padding: 12px 18px;\n    margin: 20px 0;\n    font-size: 13px;\n    line-height: 2;\n    border-radius: 0 4px 4px 0;\n  }\n  .section-title {\n    background: #1a5276;\n    color: white;\n    padding: 7px 16px;\n    font-size: 14px;\n    border-radius: 3px;\n    margin: 22px 0 10px 0;\n    font-weight: bold;\n  }\n  table.info {\n    width: 100%;\n    border-collapse: collapse;\n    margin-bottom: 10px;\n  }\n  table.info td {\n    padding: 8px 12px;\n    border-bottom: 1px solid #e8e8e8;\n    vertical-align: top;\n  }\n  table.info td:first-child {\n    font-weight: bold;\n    width: 200px;\n    color: #2c3e50;\n    background: #f7fbff;\n  }\n  table.salary {\n    width: 100%;\n    border-collapse: collapse;\n    margin: 10px 0 20px 0;\n  }\n  table.salary th {\n    background: #1a5276;\n    color: white;\n    padding: 9px 12px;\n    text-align: right;\n    font-size: 13px;\n  }\n  table.salary td {\n    padding: 8px 12px;\n    border-bottom: 1px solid #e0e0e0;\n    text-align: right;\n  }\n  table.salary tr:nth-child(even) td {\n    background: #f5f9fd;\n  }\n  .gross-row td {\n    font-weight: bold;\n    background: #d6eaf8 !important;\n    border-top: 2px solid #1a5276;\n    font-size: 14px;\n  }\n  .amount-highlight {\n    text-align: center;\n    background: #d6eaf8;\n    border: 2px solid #1a5276;\n    border-radius: 6px;\n    padding: 14px;\n    font-size: 18px;\n    font-weight: bold;\n    color: #1a5276;\n    margin: 15px 0;\n  }\n  .purpose-box {\n    background: #fef9e7;\n    border: 1px solid #f0c040;\n    border-radius: 4px;\n    padding: 12px 18px;\n    font-size: 12px;\n    color: #7d6608;\n    margin: 15px 0;\n  }\n  .validity-box {\n    background: #fdf2f8;\n    border: 1px solid #c39bd3;\n    border-radius: 4px;\n    padding: 10px 16px;\n    font-size: 12px;\n    color: #6c3483;\n    margin: 10px 0;\n    text-align: center;\n  }\n  .signature-section {\n    margin-top: 55px;\n    display: flex;\n    justify-content: space-between;\n    gap: 40px;\n  }\n  .sig-box {\n    flex: 1;\n    text-align: center;\n  }\n  .sig-line {\n    border-top: 1px solid #333;\n    margin-top: 55px;\n    padding-top: 8px;\n    font-size: 12px;\n    color: #444;\n  }\n  .footer {\n    text-align: center;\n    margin-top: 40px;\n    font-size: 10px;\n    color: #aaa;\n    border-top: 1px solid #ddd;\n    padding-top: 12px;\n  }\n  .stamp-area {\n    text-align: center;\n    margin-top: 20px;\n    border: 2px dashed #ccc;\n    padding: 20px;\n    color: #aaa;\n    font-size: 12px;\n    border-radius: 50%;\n    width: 100px;\n    height: 100px;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    margin-left: 20px;\n  }\n</style>\n</head>\n<body>\n\n{%- set company = doc.company -%}\n{%- set issue_date = frappe.utils.today() -%}\n{%- set validity_date = frappe.utils.add_months(issue_date, 3) -%}\n\n{%- set salary_assignment = frappe.db.get_value(\n    \"Salary Structure Assignment\",\n    {\"employee\": doc.name, \"docstatus\": 1},\n    [\"base\", \"from_date\"],\n    as_dict=True,\n    order_by=\"from_date desc\"\n) or {} -%}\n\n{%- set basic = salary_assignment.get(\"base\") or 0 -%}\n{%- set daily_rate = basic / 30 -%}\n\n{%- set contract = frappe.db.get_value(\n    \"Saudi Employment Contract\",\n    {\"employee\": doc.name, \"contract_status\": \"Active / \u0646\u0634\u0637\"},\n    [\"housing_allowance\", \"transport_allowance\", \"other_allowances\", \"job_title\"],\n    as_dict=True,\n    order_by=\"start_date desc\"\n) or {} -%}\n\n{%- set housing = contract.get(\"housing_allowance\") or 0 -%}\n{%- set transport = contract.get(\"transport_allowance\") or 0 -%}\n{%- set other = contract.get(\"other_allowances\") or 0 -%}\n{%- set gross = basic + housing + transport + other -%}\n{%- set job_title = contract.get(\"job_title\") or doc.designation or \"\" -%}\n\n<!-- Company Header -->\n<div class=\"header\">\n  {% if doc.company %}\n  <div style=\"font-size:15px;font-weight:bold;color:#1a1a1a;margin-bottom:4px;\">{{ doc.company }}</div>\n  {% endif %}\n  <h1>\u0634\u0647\u0627\u062f\u0629 \u0631\u0627\u062a\u0628</h1>\n  <h2>Salary Certificate</h2>\n  <div class=\"cert-number\">\u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0645\u0631\u062c\u0639\u064a: SAL-CERT-{{ doc.name }}-{{ frappe.utils.now_datetime().strftime('%Y%m%d') }}</div>\n</div>\n\n<div class=\"issue-date\">\n  \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0625\u0635\u062f\u0627\u0631: {{ frappe.format(issue_date, \"Date\") }} &nbsp;|&nbsp; Date Issued: {{ issue_date }}\n</div>\n\n<!-- To Whom It May Concern -->\n<div class=\"to-whom\">\n  <strong>\u0625\u0644\u0649 \u0645\u0646 \u064a\u0647\u0645\u0647 \u0627\u0644\u0623\u0645\u0631\u060c</strong><br>\n  \u064a\u064f\u0634\u0647\u062f \u0628\u0623\u0646 \u0627\u0644\u0645\u0648\u0638\u0641/\u0629 <strong>{{ doc.employee_name }}</strong> \u064a\u0639\u0645\u0644/\u062a\u0639\u0645\u0644 \u0644\u062f\u0649 <strong>{{ doc.company }}</strong>\n  \u0628\u0635\u0641\u0629 \u0645\u0648\u0638\u0641 \u0631\u0633\u0645\u064a \u0628\u0627\u0644\u0645\u0633\u0645\u0649 \u0627\u0644\u0648\u0638\u064a\u0641\u064a <strong>{{ job_title }}</strong>\u060c \u0648\u0623\u0646 \u0631\u0627\u062a\u0628\u0647/\u0631\u0627\u062a\u0628\u0647\u0627 \u0627\u0644\u0634\u0647\u0631\u064a \u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a \u0647\u0648\n  <strong>{{ \"{:,.2f}\".format(gross) }} \u0631\u064a\u0627\u0644 \u0633\u0639\u0648\u062f\u064a</strong> \u0643\u0645\u0627 \u0647\u0648 \u0645\u0648\u0636\u062d \u0623\u062f\u0646\u0627\u0647.\n</div>\n\n<!-- Employee Information -->\n<div class=\"section-title\">\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0648\u0638\u0641 \u2014 Employee Information</div>\n<table class=\"info\">\n  <tr>\n    <td>\u0627\u0633\u0645 \u0627\u0644\u0645\u0648\u0638\u0641</td>\n    <td>{{ doc.employee_name }}</td>\n  </tr>\n  <tr>\n    <td>\u0631\u0642\u0645 \u0627\u0644\u0645\u0648\u0638\u0641</td>\n    <td>{{ doc.name }}</td>\n  </tr>\n  <tr>\n    <td>\u0627\u0644\u0645\u0633\u0645\u0649 \u0627\u0644\u0648\u0638\u064a\u0641\u064a</td>\n    <td>{{ job_title }}</td>\n  </tr>\n  <tr>\n    <td>\u0627\u0644\u0642\u0633\u0645 / \u0627\u0644\u0625\u062f\u0627\u0631\u0629</td>\n    <td>{{ doc.department or \"\u2014\" }}</td>\n  </tr>\n  <tr>\n    <td>\u0627\u0644\u0641\u0631\u0639 / \u0627\u0644\u0645\u0648\u0642\u0639</td>\n    <td>{{ doc.branch or \"\u2014\" }}</td>\n  </tr>\n  <tr>\n    <td>\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0627\u0644\u062a\u062d\u0627\u0642 \u0628\u0627\u0644\u0639\u0645\u0644</td>\n    <td>{{ frappe.format(doc.date_of_joining, \"Date\") or \"\u2014\" }}</td>\n  </tr>\n  <tr>\n    <td>\u0627\u0644\u062c\u0646\u0633\u064a\u0629</td>\n    <td>{{ doc.nationality or \"\u2014\" }}</td>\n  </tr>\n  <tr>\n    <td>\u0631\u0642\u0645 \u0627\u0644\u0647\u0648\u064a\u0629 / \u0627\u0644\u0625\u0642\u0627\u0645\u0629</td>\n    <td>{{ doc.iqama_number or doc.passport_number or \"\u2014\" }}</td>\n  </tr>\n</table>\n\n<!-- Salary Breakdown -->\n<div class=\"section-title\">\u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0644\u0631\u0627\u062a\u0628 \u0627\u0644\u0634\u0647\u0631\u064a \u2014 Monthly Salary Breakdown</div>\n<table class=\"salary\">\n  <thead>\n    <tr>\n      <th>\u0627\u0644\u0628\u0646\u062f / Component</th>\n      <th style=\"width:200px;\">\u0627\u0644\u0645\u0628\u0644\u063a / Amount (SAR)</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <td>\u0627\u0644\u0631\u0627\u062a\u0628 \u0627\u0644\u0623\u0633\u0627\u0633\u064a / Basic Salary</td>\n      <td>{{ \"{:,.2f}\".format(basic) }}</td>\n    </tr>\n    {% if housing > 0 %}\n    <tr>\n      <td>\u0628\u062f\u0644 \u0627\u0644\u0633\u0643\u0646 / Housing Allowance</td>\n      <td>{{ \"{:,.2f}\".format(housing) }}</td>\n    </tr>\n    {% endif %}\n    {% if transport > 0 %}\n    <tr>\n      <td>\u0628\u062f\u0644 \u0627\u0644\u0645\u0648\u0627\u0635\u0644\u0627\u062a / Transport Allowance</td>\n      <td>{{ \"{:,.2f}\".format(transport) }}</td>\n    </tr>\n    {% endif %}\n    {% if other > 0 %}\n    <tr>\n      <td>\u0628\u062f\u0644\u0627\u062a \u0623\u062e\u0631\u0649 / Other Allowances</td>\n      <td>{{ \"{:,.2f}\".format(other) }}</td>\n    </tr>\n    {% endif %}\n    <tr class=\"gross-row\">\n      <td>\u0627\u0644\u0625\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0634\u0647\u0631\u064a / Total Monthly Gross</td>\n      <td>{{ \"{:,.2f}\".format(gross) }}</td>\n    </tr>\n  </tbody>\n</table>\n\n<div class=\"amount-highlight\">\n  \u0625\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0631\u0627\u062a\u0628 \u0627\u0644\u0634\u0647\u0631\u064a: {{ \"{:,.2f}\".format(gross) }} \u0631\u064a\u0627\u0644 \u0633\u0639\u0648\u062f\u064a\n</div>\n\n<!-- Purpose & Validity -->\n<div class=\"purpose-box\">\n  \ud83d\udccc \u062a\u064f\u0635\u062f\u0631 \u0647\u0630\u0647 \u0627\u0644\u0634\u0647\u0627\u062f\u0629 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0637\u0644\u0628 \u0627\u0644\u0645\u0648\u0638\u0641/\u0629 \u0644\u062a\u0642\u062f\u064a\u0645\u0647\u0627 \u0644\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0631\u0633\u0645\u064a\u0629 \u0648\u0630\u0644\u0643 \u062f\u0648\u0646 \u0623\u062f\u0646\u0649 \u0645\u0633\u0624\u0648\u0644\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0634\u0631\u0643\u0629.\n  <br>\n  This certificate is issued upon the employee's request for official purposes and carries no liability on the company.\n</div>\n\n<div class=\"validity-box\">\n  \ud83d\uddd3 \u0635\u0627\u0644\u062d\u0629 \u0644\u0645\u062f\u0629 3 \u0623\u0634\u0647\u0631 \u0645\u0646 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0625\u0635\u062f\u0627\u0631 \u2014 Valid for 3 months from date of issue ({{ validity_date }})\n</div>\n\n<!-- Signatures -->\n<div class=\"signature-section\">\n  <div class=\"sig-box\">\n    <div class=\"sig-line\">\u0645\u062f\u064a\u0631 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629<br>HR Manager</div>\n  </div>\n  <div class=\"sig-box\" style=\"text-align:center;\">\n    <div style=\"border:2px dashed #bbb;width:100px;height:100px;display:inline-flex;\n                align-items:center;justify-content:center;color:#ccc;font-size:11px;\n                border-radius:50%;margin-top:10px;\">\n      \u0627\u0644\u062e\u062a\u0645 \u0627\u0644\u0631\u0633\u0645\u064a<br>Official Stamp\n    </div>\n  </div>\n  <div class=\"sig-box\">\n    <div class=\"sig-line\">\u0627\u0644\u0645\u062f\u064a\u0631 \u0627\u0644\u0639\u0627\u0645 / \u0627\u0644\u0631\u0626\u064a\u0633 \u0627\u0644\u062a\u0646\u0641\u064a\u0630\u064a<br>General Manager / CEO</div>\n  </div>\n</div>\n\n<div class=\"footer\">\n  {{ doc.company }} &mdash; \u0646\u0638\u0627\u0645 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a &mdash;\n  \u0635\u062f\u0631\u062a \u0641\u064a: {{ frappe.utils.now_datetime().strftime('%Y-%m-%d %H:%M') }}\n</div>\n\n</body>\n</html>\n",
